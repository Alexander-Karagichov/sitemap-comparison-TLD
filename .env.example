# Fetch fallback for sitemaps that block a direct request.
# Optional: the app works with no fallback for sitemaps that aren't blocked.
#
# FETCH_PROVIDER selects the fallback: brightdata | proxy | none
# Leave it blank to auto-detect (Bright Data if a token is set, else proxy if a
# proxy URL is set, else none).
FETCH_PROVIDER=

# Option 1: Bright Data Web Unlocker (default)
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_ZONE=

# Option 2: any HTTP(S) proxy / proxy-based unlocker (ScraperAPI, Oxylabs,
# Bright Data proxy mode, your own, etc.). Format: http://user:pass@host:port
FETCH_PROXY_URL=
